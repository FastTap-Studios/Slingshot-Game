# Google AdSense (webb). Hämta client + slot från adsense.google.com.
# Sätt VITE_ADSENSE_TEST=1 för testannonser – då räknas inte klick/visningar.
VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
VITE_ADSENSE_SLOT=xxxxxxxxxx
VITE_ADSENSE_TEST=1

# Gemini API (byggs in i klienten vid npm run build)
GEMINI_API_KEY=

# Online PvP – Socket.IO-server (körs INTE på Cloudflare Pages).
# Lokalt: kör "npm run server", sedan VITE_SOCKET_URL=http://localhost:3000
# Produktion: sätt URL till din socket-server (t.ex. Railway/Fly.io), https://...
VITE_SOCKET_URL=

# Cloudflare Pages (sätt samma variabler under Project → Settings → Environment variables)
# Build command: npm run build
# Build output directory: dist
# Node version: 20
